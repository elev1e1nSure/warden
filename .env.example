# Warden Environment Variables Example
# Copy this file to .env and fill in your values

# LLM Configuration
WARDEN_MODEL=qwen3:8b
WARDEN_API_URL=

# OpenRouter API Key (for remote LLM providers)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Python Environment (usually set automatically by the launcher)
PYTHONPATH=
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
